            </h2>

            <!-- Live Calculation Box -->
            <div class="bg-slate-800 p-6 md:p-8 rounded-xl border border-slate-700 shadow-lg flex flex-col">
                <h3 class="text-xl font-medium text-white mb-6 border-b border-slate-700 pb-2">
                    <span class="en">Live Example Calculation</span>
