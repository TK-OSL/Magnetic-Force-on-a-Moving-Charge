    </div>

    <script>
        // --- 0. Language Toggle Logic ---
        const langToggle = document.getElementById('lang-toggle');
        const enBtn = document.getElementById('lang-en-btn');
        const thBtn = document.getElementById('lang-th-btn');

        function updateToggleUI() {
            const body = document.body;
            if (body.classList.contains('lang-en')) {
                enBtn.className = "px-4 py-1.5 rounded-lg text-sm font-black transition-all bg-white text-slate-700 shadow-sm";
                thBtn.className = "px-4 py-1.5 rounded-lg text-sm font-black transition-all text-orange-400 hover:text-orange-500";
            } else {
                thBtn.className = "px-4 py-1.5 rounded-lg text-sm font-black transition-all bg-white text-orange-500 shadow-sm";
                enBtn.className = "px-4 py-1.5 rounded-lg text-sm font-black transition-all text-slate-400 hover:text-slate-500";
            }
        }

        langToggle.addEventListener('click', () => {
            const body = document.body;
            if (body.classList.contains('lang-th')) {
                body.classList.replace('lang-th', 'lang-en');
            } else {
                body.classList.replace('lang-en', 'lang-th');
            }
            updateToggleUI();
        });

        updateToggleUI(); // Initialize UI state

        // --- 1. Three.js Initialization ---
        const container = document.getElementById('sim-container');
        let width = container.clientWidth;
        let height = container.clientHeight;

        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(45, width / height, 0.1, 1000);
        const defaultCamPos = new THREE.Vector3(15, 12, 20);
        camera.position.copy(defaultCamPos);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(width, height);
        renderer.setPixelRatio(window.devicePixelRatio);
        container.appendChild(renderer.domElement);

        const labelRenderer = new THREE.CSS2DRenderer();
        labelRenderer.setSize(width, height);
        labelRenderer.domElement.style.position = 'absolute';
        labelRenderer.domElement.style.top = '0px';
        labelRenderer.domElement.style.pointerEvents = 'none'; 
        container.appendChild(labelRenderer.domElement);

        const controls = new THREE.OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.dampingFactor = 0.05;
        controls.maxDistance = 50;
        controls.minDistance = 5;

        // --- 2. Lighting & Environment ---
        scene.add(new THREE.AmbientLight(0xffffff, 0.7));
        const dirLight = new THREE.DirectionalLight(0xffffff, 0.6);
        dirLight.position.set(10, 20, 10);
        scene.add(dirLight);

        scene.add(new THREE.GridHelper(40, 40, 0x334155, 0x1e293b).translateY(-5));
        scene.add(new THREE.AxesHelper(5).translateY(-5));

        const bFieldGroup = new THREE.Group();
        const bFieldMat = new THREE.LineBasicMaterial({ color: 0x22c55e, transparent: true, opacity: 0.15 });
        for(let i=-15; i<=15; i+=5) {
            for(let j=-15; j<=15; j+=5) {
                const bgArrow = new THREE.ArrowHelper(new THREE.Vector3(0,1,0), new THREE.Vector3(i,-5,j), 10, 0x22c55e, 0.6, 0.4);
                bgArrow.line.material = bFieldMat;
                bgArrow.cone.material.transparent = true; bgArrow.cone.material.opacity = 0.2;
                bFieldGroup.add(bgArrow);
            }
        }
        scene.add(bFieldGroup);

        // --- Faint Uniform B-Field Lines ---
        const bFieldLines = new THREE.Group();
        const bLineMat = new THREE.LineBasicMaterial({ color: 0x4ade80, transparent: true, opacity: 0.04 });
        for(let x = -20; x <= 20; x += 2.5) {
            for(let z = -20; z <= 20; z += 2.5) {
                // เว้นพื้นที่ตรงกลางไว้เล็กน้อย เพื่อไม่ให้เส้นบังตัวประจุและเวกเตอร์หลัก
                if (Math.abs(x) < 4 && Math.abs(z) < 4) continue;
                
                const points = [];
                points.push(new THREE.Vector3(x, -5, z));
                points.push(new THREE.Vector3(x, 25, z));
                const geo = new THREE.BufferGeometry().setFromPoints(points);
                const line = new THREE.Line(geo, bLineMat);
                bFieldLines.add(line);
            }
        }
        scene.add(bFieldLines);

        // --- 3. Physics Setup & Particles ---
        // Constants for real physics representation but scaled for visualization
        const e_charge = 1.6e-19; // Elementary charge in Coulombs
        const sys_mass = 1.6e-19; // Scaled mass (kg) so r = (m*v)/(q*B) remains visible in meters
        
        let isSimulating = false;
        let n_charge = 1; // Multiplier (-5 to +5)
        let v_mag = 5;
        let b_mag = 2;
        let angle_deg = 90;

        let pos = new THREE.Vector3(0, 0, 0);
        let vel = new THREE.Vector3(0, 0, 0);
        let B_vec = new THREE.Vector3(0, 1, 0);
        let F_vec = new THREE.Vector3(0, 0, 0);

        const particleMat = new THREE.MeshPhongMaterial({ color: 0x3b82f6, emissive: 0x1d4ed8 });
        const particle = new THREE.Mesh(new THREE.SphereGeometry(0.8, 32, 32), particleMat);
        scene.add(particle);

        const maxTrail = 800;
        const trailPos = new Float32Array(maxTrail * 3);
        const trailGeo = new THREE.BufferGeometry();
        trailGeo.setAttribute('position', new THREE.BufferAttribute(trailPos, 3));
        const trailLine = new THREE.Line(trailGeo, new THREE.LineBasicMaterial({ color: 0x94a3b8, linewidth: 2, transparent: true, opacity: 0.8 }));
        scene.add(trailLine);
        let trailCount = 0;

        // Vector Arrows & Labels
        function createLabel(txt, colClass) {
            const div = document.createElement('div');
            div.className = `vector-label ${colClass}`;
            div.innerHTML = txt;
            return new THREE.CSS2DObject(div);
        }

        const arrH_L = 1.2, arrH_W = 0.8;
        const vArrow = new THREE.ArrowHelper(new THREE.Vector3(1,0,0), pos, 1, 0x3b82f6, arrH_L, arrH_W);
        const fArrow = new THREE.ArrowHelper(new THREE.Vector3(0,0,1), pos, 1, 0xef4444, arrH_L, arrH_W);
        const bArrow = new THREE.ArrowHelper(new THREE.Vector3(0,1,0), pos, 1, 0x22c55e, arrH_L, arrH_W);
        scene.add(vArrow); scene.add(fArrow); scene.add(bArrow);

        const vLabel = createLabel('<b>v</b>', 'text-blue-400');
        const fLabel = createLabel('<b>F</b>', 'text-red-400');
        const bLabel = createLabel('<b>B</b>', 'text-green-400');
        scene.add(vLabel); scene.add(fLabel); scene.add(bLabel);

        // --- Angle Arc & Label ---
        const angleMat = new THREE.LineBasicMaterial({ color: 0xfacc15, linewidth: 2 });
        const angleArcGeo = new THREE.BufferGeometry();
        const angleArc = new THREE.Line(angleArcGeo, angleMat);
        scene.add(angleArc);
        
        const angleLabel = createLabel('<b>&theta;</b>', 'text-yellow-300 text-lg');
        scene.add(angleLabel);

        // --- 4. Camera & UI Event Listeners ---
        document.getElementById('view-x').addEventListener('click', () => { camera.position.set(25, 0, 0); controls.target.set(0,0,0); });
        document.getElementById('view-y').addEventListener('click', () => { camera.position.set(0, 25, 0); controls.target.set(0,0,0); });
        document.getElementById('view-z').addEventListener('click', () => { camera.position.set(0, 0, 25); controls.target.set(0,0,0); });
        document.getElementById('view-reset').addEventListener('click', () => { camera.position.copy(defaultCamPos); controls.target.set(0,0,0); });

        const ui = {
            qSlider: document.getElementById('q-slider'), qNum: document.getElementById('q-num'),
            vSlider: document.getElementById('v-slider'), vNum: document.getElementById('v-num'),
            bSlider: document.getElementById('b-slider'), bNum: document.getElementById('b-num'),
            angleSlider: document.getElementById('angle-slider'), angleNum: document.getElementById('angle-num'),
            btnFire: document.getElementById('btn-fire')
        };

        // Sync inputs and sliders
        function handleNumInput(numElem, sliderElem) {
            let val = parseFloat(numElem.value);
            if (!isNaN(val)) {
                sliderElem.value = val;
                updateMathDisplay();
            }
        }
        function handleSliderInput(sliderElem, numElem) {
            numElem.value = sliderElem.value;
            updateMathDisplay();
        }

        [
            { s: ui.qSlider, n: ui.qNum },
            { s: ui.vSlider, n: ui.vNum },
            { s: ui.bSlider, n: ui.bNum },
            { s: ui.angleSlider, n: ui.angleNum }
        ].forEach(pair => {
            pair.s.addEventListener('input', () => handleSliderInput(pair.s, pair.n));
            pair.n.addEventListener('input', () => handleNumInput(pair.n, pair.s));
            pair.n.addEventListener('change', () => { 
                // Enforce bounds when user finishes typing
                let val = parseFloat(pair.n.value);
                if(isNaN(val)) val = parseFloat(pair.s.value);
                const min = parseFloat(pair.s.min);
                const max = parseFloat(pair.s.max);
                if (val < min) val = min;
                if (val > max) val = max;
                pair.n.value = val;
                pair.s.value = val;
                updateMathDisplay();
            });
        });

        // Helper: Convert numbers to HTML Scientific Notation
        function toSci(num) {
            if (num === 0) return "0";
            if (!isFinite(num)) return "&infin;";
            let str = num.toExponential(2); // e.g. "1.60e-18"
            let [base, exp] = str.split('e');
            return `${base} &times; 10<sup>${parseInt(exp)}</sup>`;
        }

        function updateMathDisplay() {
            n_charge = parseFloat(ui.qNum.value) || 0;
            v_mag = parseFloat(ui.vNum.value) || 0;
            b_mag = parseFloat(ui.bNum.value) || 0;
            angle_deg = parseFloat(ui.angleNum.value) || 0;
            let actual_charge_C = n_charge * e_charge;

            const rhrHint = document.getElementById('rhr-hint');
            const isThai = document.body.classList.contains('lang-th');

            // Mass Selection for physically accurate calculation
            let actual_mass_kg = 0;
            let mass_str = "";
            let mass_sci = "";
            if (n_charge > 0) {
                actual_mass_kg = Math.abs(n_charge) * 1.67e-27; // Proton mass
                mass_str = isThai ? "มวลโปรตอน" : "Proton Mass";
                mass_sci = n_charge === 1 ? "1.67&times;10<sup>-27</sup>" : `${Math.abs(n_charge)} &times; 1.67&times;10<sup>-27</sup>`;
            } else if (n_charge < 0) {
                actual_mass_kg = Math.abs(n_charge) * 9.11e-31; // Electron mass
                mass_str = isThai ? "มวลอิเล็กตรอน" : "Electron Mass";
                mass_sci = n_charge === -1 ? "9.11&times;10<sup>-31</sup>" : `${Math.abs(n_charge)} &times; 9.11&times;10<sup>-31</sup>`;
            }

            const massDisplay = document.getElementById('mass-display');
            if (n_charge !== 0) {
                massDisplay.innerHTML = `m &approx; ${mass_sci} kg (${mass_str})`;
            } else {
                massDisplay.innerHTML = `m = 0 kg`;
            }

            if (n_charge > 0) {
                particleMat.color.setHex(0x3b82f6); particleMat.emissive.setHex(0x1d4ed8);
                rhrHint.innerHTML = isThai ? "ประจุบวก: แรง (สีแดง) ไปตามนิ้วโป้ง" : "Positive Charge: Force (Red) follows thumb.";
                rhrHint.className = "mt-3 text-xs font-semibold text-blue-400";
            } else if (n_charge < 0) {
                particleMat.color.setHex(0xef4444); particleMat.emissive.setHex(0xb91c1c);
                rhrHint.innerHTML = isThai ? "ประจุลบ: แรง (สีแดง) ตรงข้ามกับนิ้วโป้ง" : "Negative Charge: Force (Red) OPPOSITE to thumb.";
                rhrHint.className = "mt-3 text-xs font-semibold text-red-400";
            } else {
                particleMat.color.setHex(0x94a3b8); particleMat.emissive.setHex(0x475569);
                rhrHint.innerHTML = isThai ? "เป็นกลางทางไฟฟ้า: ไม่มีแรงแม่เหล็ก" : "Neutral Particle: No magnetic force.";
                rhrHint.className = "mt-3 text-xs font-semibold text-slate-400";
            }

            // Math Calculations
            const angle_rad = THREE.MathUtils.degToRad(angle_deg);
            const sin_val = Math.sin(angle_rad);
            const force_mag = Math.abs(actual_charge_C) * v_mag * b_mag * sin_val;
            
            // Format q for display
            let qStr = n_charge !== 0 ? `${Math.abs(n_charge)} &times; 1.6 &times; 10<sup>-19</sup>` : "0";
            
            document.getElementById('c-q').innerHTML = qStr;
            document.getElementById('c-v').innerText = v_mag;
            document.getElementById('c-b').innerText = b_mag;
            document.getElementById('c-ang').innerText = angle_deg;
            document.getElementById('res-f').innerHTML = toSci(force_mag);

            const v_perp = v_mag * sin_val;
            document.getElementById('c-v2').innerText = v_mag;
            document.getElementById('c-sin').innerText = sin_val.toFixed(2);
            document.getElementById('c-q2').innerHTML = qStr;
            document.getElementById('c-b2').innerText = b_mag;
            document.getElementById('c-m').innerHTML = n_charge !== 0 ? mass_sci : "0";
            
            const resREl = document.getElementById('res-r');
            if (Math.abs(actual_charge_C) > 0 && b_mag > 0 && v_perp > 0) {
                // Real physics radius
                const radius = (actual_mass_kg * v_perp) / (Math.abs(actual_charge_C) * b_mag);
                resREl.innerHTML = toSci(radius) + " m";
            } else if (v_perp === 0) {
                resREl.innerText = "∞ (Straight / เส้นตรง)";
            } else {
                resREl.innerText = "∞ (No Force / ไม่มีแรง)";
            }

            if (!isSimulating) setupInitialState();
        }

        // Update RHR Hint text on language change
        langToggle.addEventListener('click', updateMathDisplay);

        // --- 5. Animation Helpers & Engine ---
        function updateVectors() {
            bArrow.position.copy(pos); bArrow.setDirection(new THREE.Vector3(0, 1, 0));
            let bLen = b_mag * 1.5; bArrow.setLength(bLen, arrH_L, arrH_W);
            bLabel.position.copy(pos).add(new THREE.Vector3(0, bLen + 0.5, 0));

            vArrow.position.copy(pos);
            if(vel.lengthSq() > 0) {
                let vDir = vel.clone().normalize(); vArrow.setDirection(vDir);
                let vLen = v_mag * 0.4 + 2; vArrow.setLength(vLen, arrH_L, arrH_W);
                vLabel.position.copy(pos).add(vDir.multiplyScalar(vLen + 0.5));
                vLabel.visible = true;
            } else { vLabel.visible = false; }

            fArrow.position.copy(pos);
            if(F_vec.lengthSq() > 0.001) {
                let fDir = F_vec.clone().normalize(); fArrow.setDirection(fDir);
                // Scale visual force purely based on n, v, B to fit screen
                let visualFLen = Math.abs(n_charge) * v_mag * b_mag * Math.sin(THREE.MathUtils.degToRad(angle_deg)) * 0.2 + 2;
                fArrow.setLength(visualFLen, arrH_L, arrH_W);
                fLabel.position.copy(pos).add(fDir.multiplyScalar(visualFLen + 0.5));
                fArrow.visible = true; fLabel.visible = true;
            } else { fArrow.visible = false; fLabel.visible = false; }

            // Show Launch Angle Arc only when setting up (not simulating)
            if (!isSimulating && angle_deg > 0 && v_mag > 0) {
                angleArc.visible = true;
                angleLabel.visible = true;
                
                const a_rad = THREE.MathUtils.degToRad(angle_deg);
                const arcRadius = 2.5; 
                const points = [];
                // Generate points for the arc from B-vector (Y-axis) to v-vector
                for(let i = 0; i <= 20; i++) {
                    const t = i / 20;
                    const currA = t * a_rad;
                    points.push(new THREE.Vector3(pos.x + arcRadius * Math.sin(currA), pos.y + arcRadius * Math.cos(currA), pos.z));
                }
                angleArcGeo.setFromPoints(points);

                // Position the theta label at the middle of the arc
                const midA = a_rad / 2;
                angleLabel.position.set(pos.x + (arcRadius + 0.6) * Math.sin(midA), pos.y + (arcRadius + 0.6) * Math.cos(midA), pos.z);
            } else {
                angleArc.visible = false;
                angleLabel.visible = false;
            }
        }

        function setupInitialState() {
            isSimulating = false; pos.set(0, 0, 0); particle.position.copy(pos);
            const a_rad = THREE.MathUtils.degToRad(angle_deg);
            vel.set(v_mag * Math.sin(a_rad), v_mag * Math.cos(a_rad), 0);
            B_vec.set(0, b_mag, 0);
            // Visual force direction cross product (treat charge sign simply)
            F_vec.crossVectors(vel, B_vec).multiplyScalar(n_charge);
            
            updateVectors();
            trailCount = 0; trailGeo.setDrawRange(0, 0);
        }

        ui.btnFire.addEventListener('click', () => {
            const isThai = document.body.classList.contains('lang-th');
            if(!isSimulating) {
                setupInitialState(); isSimulating = true;
                ui.btnFire.innerHTML = isThai ? "<span class='th'>หยุดชั่วคราว</span>" : "<span class='en'>Pause Simulation</span>";
                ui.btnFire.className = "font-bold py-3 px-4 rounded transition-colors shadow-lg bg-red-600 hover:bg-red-500 shadow-red-500/30 text-white";
            } else {
                isSimulating = false;
                ui.btnFire.innerHTML = isThai ? "<span class='th'>เล่นต่อ</span>" : "<span class='en'>Resume Simulation</span>";
                ui.btnFire.className = "font-bold py-3 px-4 rounded transition-colors shadow-lg bg-blue-600 hover:bg-blue-500 shadow-blue-500/20 text-white";
            }
        });

        document.getElementById('btn-reset').addEventListener('click', () => {
            setupInitialState();
            const isThai = document.body.classList.contains('lang-th');
            ui.btnFire.innerHTML = isThai ? "<span class='th'>ยิงประจุ / เริ่มการทำงาน</span>" : "<span class='en'>Play Simulation</span>";
            ui.btnFire.className = "font-bold py-3 px-4 rounded transition-colors shadow-lg bg-blue-600 hover:bg-blue-500 shadow-blue-500/20 text-white";
        });

        const clock = new THREE.Clock();
        function animate() {
            requestAnimationFrame(animate);
            controls.update();

            if (isSimulating) {
                const dt = Math.min(clock.getDelta(), 0.05);

                B_vec.set(0, b_mag, 0); 
                // Physics engine uses n_charge directly for visual trajectory (since mass is scaled accordingly)
                F_vec.crossVectors(vel, B_vec).multiplyScalar(n_charge);
                const acc = F_vec.clone(); // Since m = 1 in simulation scale terms
                
                vel.add(acc.multiplyScalar(dt));
                
                // FIX: Magnetic force does NO work, so speed must remain strictly constant!
                // This prevents the radius from expanding due to numerical integration errors (Euler method drift).
                if (vel.lengthSq() > 0) {
                    vel.setLength(v_mag);
                }

                pos.add(vel.clone().multiplyScalar(dt));

                particle.position.copy(pos);
                updateVectors();

                if (trailCount < maxTrail) {
                    trailPos[trailCount * 3] = pos.x; trailPos[trailCount * 3 + 1] = pos.y; trailPos[trailCount * 3 + 2] = pos.z;
                    trailCount++;
                    trailGeo.setDrawRange(0, trailCount); trailGeo.attributes.position.needsUpdate = true;
                } else {
                    for(let i=0; i< (maxTrail-1)*3; i++) trailPos[i] = trailPos[i+3];
                    trailPos[(maxTrail-1)*3] = pos.x; trailPos[(maxTrail-1)*3 + 1] = pos.y; trailPos[(maxTrail-1)*3 + 2] = pos.z;
                    trailGeo.attributes.position.needsUpdate = true;
                }
            } else { clock.getDelta(); }

            renderer.render(scene, camera);
            labelRenderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            width = container.clientWidth; height = container.clientHeight;
            camera.aspect = width / height; camera.updateProjectionMatrix();
            renderer.setSize(width, height); labelRenderer.setSize(width, height);
        });

        window.onload = () => { updateMathDisplay(); setupInitialState(); animate(); };
    </script>
</body>
</html>
